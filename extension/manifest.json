{
  "manifest_version": 3,
  "name": "VisionAdapt — Polymorph AI",
  "version": "4.2.0",
  "description": "Polymorph AI automatically analyzes every webpage and applies the best accessibility settings — color blindness filters, contrast, typography — synced across devices.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "VisionAdapt — Polymorph AI"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "https://a11ai.lovable.app/*",
        "https://*.lovable.app/*",
        "https://*.lovable.dev/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    },
    {
      "matches": [
        "https://a11ai.lovable.app/*",
        "https://*.lovable.app/extension-link*",
        "https://*.lovable.dev/extension-link*"
      ],
      "js": ["link-bridge.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
